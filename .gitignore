# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Scratch space for transient files (screenshots, etc.) — never committed
tmp/

# Amplify Gen2 — generated per-environment (sandbox/deploy), don't commit
.amplify
amplify_outputs.json

# utils/user-admin: environment IDs (Cognito pool, table names, region) — not secrets,
# but identifying info about this developer's setup that shouldn't be pushed. The tool
# creates this with blank fields on first run if it's missing.
utils/user-admin/config.json

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store

# Claude Code: local/personal settings only — skills/commands under .claude/skills
# and .claude/commands are project infrastructure and should be committed
.claude/settings.local.json
.claude/scheduled_tasks.lock
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
